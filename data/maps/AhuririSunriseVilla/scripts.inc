AhuririSunriseVilla_MapScripts::
	.byte 0

AhuririSunriseVilla_EventScript_DecoMan::
	lock
	faceplayer
	msgbox AhuririSunriseVilla_Text_DecoMan, MSGBOX_DEFAULT
	release
	end

AhuririSunriseVilla_Text_DecoMan:
	.string "Nineteen thirty-one. The earth\n"
	.string "threw this whole city down,\l"
	.string "and we built it back deco.\p"
	.string "Straight lines, sunrise motifs.\n"
	.string "A promise in plaster: we are\l"
	.string "not afraid of mornings.$"


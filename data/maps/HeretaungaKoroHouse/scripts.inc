HeretaungaKoroHouse_MapScripts::
	.byte 0

HeretaungaKoroHouse_EventScript_Koro::
	lock
	faceplayer
	msgbox HeretaungaKoroHouse_Text_Koro, MSGBOX_DEFAULT
	release
	end

HeretaungaKoroHouse_Text_Koro:
	.string "See Te Mata out the window?\n"
	.string "That ridge is a giant, boy.\l"
	.string "Rongokako, sleeping.\p"
	.string "My koro told me, and his koro\n"
	.string "told him: one day the land\l"
	.string "will stretch and yawn.\p"
	.string "When it does, you be standing\n"
	.string "somewhere that matters.$"

